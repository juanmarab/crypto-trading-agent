# CryptoAgent API — Environment Variables
# Copy this file to .env and fill in your real values.
# The docker-compose.yml reads from this file automatically.

# ── Binance (optional for REST; required for authenticated endpoints) ─────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── CryptoPanic (free-tier: https://cryptopanic.com/developers/api/) ─────────
CRYPTOPANIC_API_KEY=

# ── Google Gemini (for LLM decisions + embeddings) ───────────────────────────
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# ── Telegram Bot Token ────────────────────────────────────────────────────────
# Create a bot: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
