# CryptoAgent API — Environment Variables Template
# Copy this file to .env and fill in your real values.
# The docker-compose.yml reads from .env automatically.
# ⚠️  NEVER put real keys in THIS file — it is tracked by Git.

# ── Binance (optional for REST; required for authenticated endpoints) ─────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── CryptoPanic (free-tier: https://cryptopanic.com/developers/api/) ─────────
CRYPTOPANIC_API_KEY=

# ── LLM: Groq — RECOMMENDED (fastest, fully free) ────────────────────────────
# Sign up at: https://console.groq.com/keys (no credit card required)
GROQ_API_KEY=

# ── LLM fallback: Google Gemini (also used for embeddings) ───────────────────
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# ── Telegram Bot Token ────────────────────────────────────────────────────────
# Create a bot: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
